# ─────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────
# Postgres connection string (provisioned automatically on Replit)
DATABASE_URL=postgres://user:password@host:5432/db

# Admin password used to gate /api/admin/* endpoints.
# In production this MUST be set or the server will refuse to start.
# In development a 'dev-admin' fallback is used if unset.
# Store as a Replit Secret, NEVER commit the real value.
ADMIN_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────
# Optional — runtime / hosting
# ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Public origin used for LINE OAuth callbacks
PUBLIC_ORIGIN=https://your-app.replit.app

# ─────────────────────────────────────────────────────────────
# Feature flags — set to "0", "false", or "off" to disable.
# Defaults to enabled when unset.
# ─────────────────────────────────────────────────────────────
ENABLE_SCHOOL_MODULE=1
ENABLE_LINE_NOTIFY=1
ENABLE_RAGIC_SYNC=1

# Task #23 — weekly push pipeline (pg-boss). Both default OFF.
# Set to "1" to register the queue + cron (production deploy only)
# and to start the worker process inside this server.
ENABLE_WEEKLY_PUSH_QUEUE=0
ENABLE_WEEKLY_PUSH_WORKER=0
# Cron expression + tz for the weekly auto-trigger when the queue is on.
# Default = Sunday 19:00 Asia/Taipei.
WEEKLY_PUSH_CRON=0 19 * * 0
WEEKLY_PUSH_TIMEZONE=Asia/Taipei
# CSV vs xlsx for the per-run report. CSV is the only built-in format today.

# ─────────────────────────────────────────────────────────────
# Optional — Healthchecks.io watchdog for the weekly push
# ─────────────────────────────────────────────────────────────
# Base URL of the Healthchecks check (no trailing slash). When unset
# the worker still runs but only logs a warning instead of pinging.
HEALTHCHECKS_WEEKLY_PUSH_URL=
HEALTHCHECKS_WEEKLY_PUSH_ENABLED=1

# ─────────────────────────────────────────────────────────────
# Optional — LINE group IDs for the weekly push summary report
# ─────────────────────────────────────────────────────────────
# IT operations channel (always receives summary if set).
LINE_IT_GROUP_ID=
# 協同課 user-facing channel (only receives summary if set).
LINE_XIE_TONG_GROUP_ID=

# ─────────────────────────────────────────────────────────────
# Optional — LINE integrations (push notify + login)
# ─────────────────────────────────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# Optional — Ragic sync
# ─────────────────────────────────────────────────────────────
RAGIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Replit-managed (do not edit manually)
# ─────────────────────────────────────────────────────────────
# REPLIT_DEPLOYMENT, REPLIT_DOMAINS, REPL_ID, SESSION_SECRET, etc.
